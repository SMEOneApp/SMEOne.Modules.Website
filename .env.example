# SQL Server connection string — used to persist waitlist sign-ups to the database.
# Format: sqlserver://HOST;database=DB;user=USER;password=PASS;trustServerCertificate=true
DATABASE_URL="sqlserver://SQL8012.site4now.net;database=db_ac676b_smeonetestdb;user=db_ac676b_smeonetestdb_admin;password=database1;trustServerCertificate=true"

BREVO_API_KEY=your_brevo_api_key_here
BREVO_LIST_NAME=WAITLIST
# Optional. Only change this if you need the list created in a non-default Brevo folder.
BREVO_FOLDER_ID=1
# Not used by the simple waitlist flow below unless you later add confirmation emails.
BREVO_FROM_NAME=SmeOne Africa
BREVO_FROM_EMAIL=hello@smeone.africa

# SMTP — used to send the waitlist confirmation email to new sign-ups.
# Uses Gmail with an App Password (same setup as SMEOne.Modules.Monolith).
# Generate an App Password at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=smeoneafrica@gmail.com
SMTP_PASS=your_gmail_app_password_here
SMTP_FROM_NAME=SMEOne
SMTP_FROM_EMAIL=smeoneafrica@gmail.com

# Public URL of the deployed site — used in email template links and images.
SITE_URL=https://smeone.africa
